# API Keys
ANTHROPIC_API_KEY=your-api-key-here
TMDB_API_KEY=your-tmdb-api-key-here

# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# Database (Railway provides postgresql://, app auto-converts to postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://filmmatch:filmmatch@localhost:5432/filmmatch

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-key
MAGIC_LINK_SECRET=change-this-to-another-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend — leave blank to disable, tokens returned in response for dev)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FilmMatch <noreply@filmmatch.ai>
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_RECOMMENDATIONS_PER_MINUTE=10

# Monitoring (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
